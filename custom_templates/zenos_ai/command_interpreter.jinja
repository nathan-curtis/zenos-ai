{%- set ma_entity_id = ma | selectattr('entity_id', 'in', room_players )
      | map(attribute='entity_id')
      | list | first -%}
{%- set video = expand(label_entities('video_output')) -%}
{%- set video_entity_id = video | selectattr('entity_id', 'in', room_players )
      | map(attribute='entity_id')
      | list | first -%}
{%- set voice = expand(label_entities('voice_assistant')) -%}
{%- set voice_assistant_id = voice | selectattr('entity_id', 'in', room_players )
      | map(attribute='entity_id')
      | list | first -%}
{%- set universal = expand(label_entities('universal_media_player')) -%}
{%- set universal_media_id = universal | selectattr('entity_id', 'in', room_players )
