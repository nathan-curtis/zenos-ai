{%- set tts_entity_id = tts | selectattr('entity_id', 'in', room_players )
      | map(attribute='entity_id')
      | list | first -%}
{%- set audio = expand(label_entities('audio_output')) -%}
{%- set audio_entity_id = audio | selectattr('entity_id', 'in', room_players )
      | map(attribute='entity_id')
      | list | first -%}
