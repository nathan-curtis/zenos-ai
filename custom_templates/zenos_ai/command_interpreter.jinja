{%- macro almanac_json() -%}
{%- set now_ts = now().isoformat() -%}

{# RESOLVE SEASON ENTITY #}
{%- set season_entity = 'sensor.season' %}
{%- if states(season_entity) in ['unknown','unavailable',''] %}
  {%- set season_candidates = expand(label_entities('season'))
      | selectattr('domain','eq','sensor')
      | map(attribute='entity_id')
      | list %}
  {%- if season_candidates|length > 0 %}
    {%- set season_entity = season_candidates[0] %}
  {%- endif %}
{%- endif %}
{%- set season_value = states(season_entity)
    if states(season_entity) not in ['unknown','unavailable','']
    else "missing" %}

{# RESOLVE MOON PHASE #}
{%- set moon_entity = 'sensor.moon_phase' %}
{%- if states(moon_entity) in ['unknown','unavailable',''] %}
  {%- set moon_candidates = expand(label_entities('moon_phase'))
      | selectattr('domain','eq','sensor')
      | map(attribute='entity_id')
      | list %}
  {%- if moon_candidates|length > 0 %}
    {%- set moon_entity = moon_candidates[0] %}
  {%- endif %}
{%- endif %}
{%- set moon_value = states(moon_entity)
    if states(moon_entity) not in ['unknown','unavailable','']
    else "missing" %}

{# SUN #}
{%- set sun_raw = states['sun.sun'] if states.get('sun.sun') else "missing" %}

{# HOME MODE #}
{%- set home_mode_entities = expand(label_entities('home_mode'))
    | selectattr('domain','eq','input_select')
    | map(attribute='entity_id')
    | list %}
{%- if home_mode_entities|length > 0 %}
  {%- set home_mode = home_mode_entities[0] %}
{%- else %}
  {%- set home_mode = 'input_select.zen_home_mode' %}
{%- endif %}
{%- set home_mode_val = states(home_mode)
    if states(home_mode) not in ['unknown','unavailable','']
    else "missing" %}

{# DAY SCHEDULE BLOCK #}
{%- set schedule_map = {
    'wake': 'input_datetime.zen_am_start',
    'morning': 'input_datetime.zen_morning_start',
    'daytime': 'input_datetime.zen_daytime_start',
    'evening': 'input_datetime.zen_evening_start',
    'night': 'input_datetime.zen_night_start',
    'late_night': 'input_datetime.zen_late_night_start'
  }
-%}

{%- set schedule_json = {} %}
{%- for key, entity in schedule_map.items() %}
  {%- if states(entity) not in ['unknown','unavailable',''] %}
    {%- set _ = schedule_json.update({ key: (states(entity) | today_at).isoformat() }) %}
  {%- else %}
    {%- set _ = schedule_json.update({ key: "missing" }) %}
  {%- endif %}
{%- endfor %}

{# CALENDARS (label: almanac) #}
{%- set calendar_entities = expand(label_entities('almanac'))
    | selectattr('domain','eq','sensor')
    | map(attribute='entity_id')
    | list %}
{%- set calendar_json = [] %}

{%- for cal in calendar_entities %}
  {%- set cal_name = state_attr(cal,'friendly_name') or cal %}
  {%- set events = state_attr(cal,'events') or [] %}
  {%- set cal_entry = {
      "entity_id": cal,
      "name": cal_name,
      "labels": labels(cal),
      "events": events
    } %}
  {%- set _ = calendar_json.append(cal_entry) %}
{%- endfor %}

{%- if calendar_json|length == 0 %}
  {%- set calendar_json = [{ "status": "no_almanac_calendars",
                             "hint": "tag calendar sensors with 'almanac'" }] %}
{%- endif %}

{# ILLUMINANCE #}
{%- set illum_labeled = expand(label_entities('illuminance'))
    | selectattr('domain','eq','sensor')
    | map(attribute='entity_id')
    | list %}
{%- if illum_labeled|length > 0 %}
  {%- set illum_entity = illum_labeled[0] %}
{%- else %}
  {%- set lux_sensors = states.sensor
      | selectattr('attributes.unit_of_measurement','in',['lx','lux'])
      | map(attribute='entity_id')
      | list %}
  {%- if lux_sensors|length > 0 %}
    {%- set illum_entity = lux_sensors[0] %}
  {%- else %}
    {%- set illum_entity = none %}
  {%- endif %}
{%- endif %}

{%- if illum_entity %}
  {%- set illum_val = states(illum_entity)
      if states(illum_entity) not in ['unknown','unavailable','']
      else "missing" %}
{%- else %}
  {%- set illum_val = "missing" %}
{%- endif %}

{# WEATHER PROVIDER #}
{%- set wx_labeled = expand(label_entities('weather'))
    | selectattr('domain','eq','weather')
    | map(attribute='entity_id')
    | list %}
{%- if wx_labeled|length > 0 %}
  {%- set weather_entity = wx_labeled[0] %}
{%- else %}
  {%- set weather_entity = states.weather | map(attribute='entity_id') | first | default(none) %}
{%- endif %}
{%- set weather_state = states(weather_entity)
    if weather_entity and states(weather_entity) not in ['unknown','unavailable','']
    else "missing" %}

{# WEATHER ALERTS #}
{%- set alert_entities = expand(label_entities('weather_alerts'))
    | selectattr('domain','eq','sensor')
    | map(attribute='entity_id')
    | list %}
{%- if alert_entities|length == 0 %}
  {%- set alert_entities = expand(label_entities('alerts'))
      | selectattr('domain','eq','sensor')
      | map(attribute='entity_id')
      | list %}
{%- endif %}

{%- if alert_entities|length > 0 %}
  {%- set alert_entity = alert_entities[0] %}
  {%- set alerts = state_attr(alert_entity,'alerts')
      or state_attr(alert_entity,'active_alerts')
      or state_attr(alert_entity,'active')
      or [] %}
{%- else %}
  {%- set alerts = "missing" %}
{%- endif %}

{# FORECAST #}
{%- set forecast_entities = expand(label_entities('weather_forecast'))
    | selectattr('domain','eq','sensor')
    | map(attribute='entity_id')
    | list %}
{%- if forecast_entities|length > 0 %}
  {%- set forecast_entity = forecast_entities[0] %}
{%- else %}
  {%- set forecast_entity = 'sensor.weather_forecast_daily' %}
{%- endif %}
{%- set forecast = state_attr(forecast_entity,'forecast') or "missing" %}

{# HISTORICAL WEATHER #}
{%- set stats_entities = expand(label_entities('weather_stats'))
    | selectattr('domain','eq','sensor')
    | map(attribute='entity_id')
    | list %}
{%- if stats_entities|length > 0 %}
  {%- set stats_entity = stats_entities[0] %}
{%- else %}
  {%- set stats_entity = 'sensor.weather_stats' %}
{%- endif %}
{%- set stats_attrs =
    states[stats_entity].attributes if states.get(stats_entity)
    and states(stats_entity) not in ['unknown','unavailable','']
    else "missing" %}

{# FINAL JSON OUTPUT #}
{
  "timestamp": "{{ now_ts }}",
  "timetable": {
    "season": "{{ season_value }}",
    "moon_phase": "{{ moon_value }}",
    "sun": "{{ sun_raw }}"
  },
  "home_mode": {
    "entity": "{{ home_mode }}",
    "value": "{{ home_mode_val }}"
  },
  "schedule": {{ schedule_json | tojson }},
  "calendar": {{ calendar_json | tojson }},
  "environment": {
    "illuminance": "{{ illum_val }}"
  },
  "weather": {
    "provider": "{{ weather_entity if weather_entity else 'missing' }}",
    "state": "{{ weather_state }}",
    "alerts": {{ alerts | tojson }},
    "forecast": {{ forecast | tojson }}
  },
  "weather_stats": {{ stats_attrs | tojson }}
}
{%- endmacro -%}

