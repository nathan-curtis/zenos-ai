{%- macro taskmaster_json() -%}
{#- PII-safe: configure label 'ai_user' for the AI's task list and 'household' for family chores. -#}
{%- set this_ai = 'friday' -%}
{%- set this_family = 'household' -%}
{%- set this_ai_task_lists = label_entities(this_ai) | sort -%}
{%- set ai_task_lists = label_entities('AI Task List') | sort -%}
{%- set this_family_entities = label_entities(this_family) | sort -%}
{%- set taskmaster = label_entities('taskmaster') | sort -%}
{%- set task_lists = label_entities('tasks') | sort -%}
{%- set taskmaster_lists = states.todo
                    | map(attribute='entity_id')
                    | select('in',taskmaster)
                    | list
                    | sort -%}
{%- set taskmaster_calendar_sensors = states.sensor
                    | map(attribute='entity_id')
                    | select('in',taskmaster)
                    | list
                    | sort -%}
{%- set chores = label_entities('chores') | sort -%}
{%- set chore_lists = intersect(chores, task_lists) | sort -%}
{%- set this_family_task_lists =  intersect(this_family_entities, task_lists) | sort -%}
{%- set this_family_chore_lists =  intersect(this_family_task_lists, chore_lists) | sort -%}
{%- set taskmaster_chore_lists = intersect(taskmaster_lists, chore_lists) | sort -%}
{%- set taskmaster_ai_lists = intersect(taskmaster_lists, ai_task_lists) | sort -%}
{%- set this_ai_taskmaster_list = (intersect(taskmaster_ai_lists, this_ai_task_lists) | sort | first ) or '' -%}
{%- set this_family_taskmaster_chore_list = (intersect(this_family_chore_lists, taskmaster_chore_lists) | sort | first ) or '' -%}
{%- set fam_taskmaster_calendars =  (intersect(this_family_entities, taskmaster_calendar_sensors)) | sort -%}

{%- set todos1 = state_attr(this_ai_taskmaster_list, 'all_todos') or [] -%}
{%- set ns = namespace(personal_tasks=[]) -%}
{%- for todo in todos1 -%}
  {% set subject = todo.get('subject', '') -%}
  {% set description = todo.get('description', '') -%}
  {% set due = todo.get('due', '') -%}
  {% set status = todo.get('status', '') -%}
  {% set ns.personal_tasks = ns.personal_tasks + [{
    "subject": subject|trim|default(''),
    "description": description|trim|default(''),
    "due": (due|string)|default(''),
    "status": status|default('')
  }] -%}
{%- endfor -%}
{%- set personal_tasks = ns.personal_tasks |tojson -%}

{% set todos2 = state_attr(this_family_taskmaster_chore_list, 'all_todos') or [] -%}
{%- set ns = namespace(household_chores=[]) -%}
{%- for todo in todos2 -%}
  {% set subject = todo.get('subject', '') -%}
  {% set description = todo.get('description', '') -%}
  {% set due = todo.get('due', '') -%}
  {% set status = todo.get('status', '') -%}
  {% set ns.household_chores = ns.household_chores + [{
    "subject": subject|trim|default(''),
    "description": description|trim|default(''),
    "due": (due|string)|default(''),
    "status": status|default('')
  }] -%}
{%- endfor -%}
{%- set household_chores = ns.household_chores | tojson -%}

{%- set ns = namespace(tracked_calendars=[]) -%}
{%- for calendar_sensor in fam_taskmaster_calendars %}
  {%- set events = state_attr(calendar_sensor, 'events') or [] -%}
  {%- set ev = namespace(list=[]) -%}

  {%- for e in events %}
    {%- set ev.list = ev.list + [{
      "start": e.get('start', '') | string,
      "end": e.get('end', '') | string,
      "summary": e.get('summary', '') | string,
      "description": e.get('description', '') | string
    }] -%}
  {%- endfor %}

  {%- set ns.tracked_calendars = ns.tracked_calendars + [{
    "entity_id": calendar_sensor,
    "friendly_name": state_attr(calendar_sensor, 'friendly_name') | default(''),
    "labels": labels(calendar_sensor) | default([]),
    "events": ev.list
  }] -%}
{%- endfor %}
{%- set tracked_calendars = ns.tracked_calendars | tojson -%}

{%- set obj = {
  "version": "2.0.0",
  "command": "TASKMASTER",
  "timestamp": now().isoformat(),
  "status": "OK",
  "personal_tasks": personal_tasks | default({}),
  "household_chores": household_chores | default({}),
  "calendar": tracked_calendars | default({}),
} -%}
{{ obj | to_json }}
{%- endmacro -%}

