{#  TODO LIST READER                                            #}
{# ============================================================ #}

{%- macro read_todo_list_raw(entity_id) -%}
{%- if (not (entity_id)) or (entity_id == '') -%}
ERROR: read_todo_list_raw: entity_id not provided
{%- else -%}
todo_entity_id: '{{entity_id}}'
{% set today = today_at('00:00') -%}
{%- set tomorrow = today + timedelta(days=1) -%}

{%- for todo in state_attr(entity_id, 'all_todos') -%}
  {%- if todo.due is defined -%}
    {%- set due = todo.due | as_datetime() | as_local() -%}
  {%- else -%}
    {%- set due = today -%}
  {%- endif -%}
  {%- if today >= due %}
Today:
subject: '{{ todo.subject }}'
due: {{ due }}
status: {{ todo.status }}
    {%- if todo.description is defined %}
description: {{ todo.description }}
    {%- else %}
description: none
    {% endif -%}
  {%- endif -%}
  {%- if tomorrow == due -%}
Tomorrow:
subject: '{{ todo.subject }}'
id: {{ todo.todo_id }}
due: {{ due }}
status: {{ todo.status }}
    {%- if todo.description is defined %}
description: {{ todo.description }}
    {%- else %}
description: none
    {%- endif -%}
  {%- endif -%}
{%- endfor %}
{%- endif -%}
{%- endmacro -%}

