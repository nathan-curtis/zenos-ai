{%- macro interpreter(query) -%}
  {%- if query != '' -%}
    {%- set command = query -%}
    {%- set first_tilde = command.find('~') -%}
    {%- set second_tilde = command.find('~', first_tilde + 1) -%}
    {%- set user_id = (command.split('@')[1] if '@' in command else '') -%}
    {%- set household = ('{' + command.split('{')[1].split('}')[0] + '}' if '{' in command and '}' in command else '') -%}
    {%- set main_command = command[first_tilde:second_tilde + 1] -%}
    {%- set remaining_args = command[second_tilde + 1:] -%}
  {%- else -%}
    {%- set user_id = '' -%}
    {%- set household = '' -%}
    {%- set main_command = '*' -%}
    {%- set remaining_args = '' -%}
  {%- endif -%}
  {{ render_cmd_window(user_id, household, main_command, remaining_args) }}
{%- endmacro -%}
