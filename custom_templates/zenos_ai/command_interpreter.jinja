{%- macro weather_alert_json() -%}
{%- set SENSOR = 'sensor.weatheralerts_1_active_alerts' -%}
{%- set alert_counters = [
    'warning_count', 'watch_count', 'advisory_count', 'statement_count',
    'outlook_count', 'alert_count', 'message_count', 'important_count', 'test_count'
] -%}
{%- set ns = namespace(any_alerts=false) %}
{%- for counter in alert_counters %}
  {%- if (states[SENSOR].attributes[counter] | int(0)) > 0 %}
    {%- set ns.any_alerts = true -%}
  {%- endif %}
{%- endfor %}
{
  "entity_id": "{{ SENSOR }}",
  "warning_count": {{ states[SENSOR].attributes.warning_count | int }},
  "watch_count": {{ states[SENSOR].attributes.watch_count | int }},
  "advisory_count": {{ states[SENSOR].attributes.advisory_count | int }},
  "statement_count": {{ states[SENSOR].attributes.statement_count | int }},
  "outlook_count": {{ states[SENSOR].attributes.outlook_count | int }},
  "alert_count": {{ states[SENSOR].attributes.alert_count | int }},
  "message_count": {{ states[SENSOR].attributes.message_count | int }},
  "important_count": {{ states[SENSOR].attributes.important_count | int }},
  "test_count": {{ states[SENSOR].attributes.test_count | int }},
  "unit_of_measurement": "{{ states[SENSOR].attributes.unit_of_measurement }}",
  "icon": "{{ states[SENSOR].attributes.icon }}",
  "friendly_name": "{{ states[SENSOR].attributes.friendly_name }}",
  "alerts": [
    {%- if ns.any_alerts %}
      {%- set SENSOR2 = 'sensor.weatheralerts_1_alert_1' -%}
      {
        "entity_id": "{{ SENSOR2 }}"{% for attr in states[SENSOR2].attributes %}
        , "{{ attr }}": {{ states[SENSOR2].attributes[attr] | tojson }}{% endfor %}
      }
    {%- endif %}
  ]
}
{%- endmacro-%}

